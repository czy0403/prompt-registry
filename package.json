{
  "name": "prompt-registry",
  "version": "0.1.0",
  "private": true,
  "description": "A focused Prompt Registry with immutable versions and label-based releases.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/server.ts",
    "start": "node --env-file-if-exists=.env dist/src/server.js",
    "db:migrate": "node --env-file-if-exists=.env --import tsx src/db/migrate.ts",
    "test": "node --env-file-if-exists=.env --import tsx --test --test-concurrency=1 test/*.test.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
