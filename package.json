{
  "name": "prompt-registry",
  "version": "0.1.0",
  "private": true,
  "description": "A focused Prompt Registry with immutable versions and label-based releases.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/server.ts",
    "example": "python3 example/python-client.py",
    "start": "node --env-file-if-exists=.env dist/src/server.js",
    "db:migrate": "node --env-file-if-exists=.env --import tsx src/db/migrate.ts",
    "test": "node --env-file-if-exists=.env --import tsx --test --test-concurrency=1 test/*.test.ts",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:full": "TEST_DATABASE_URL=postgres://prompt_registry:test_password@127.0.0.1:55432/prompt_registry_test npm test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
